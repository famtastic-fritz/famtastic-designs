<article class="campaign-page">
  <style>
    .campaign-page {
      max-width: 1100px;
      margin: 0 auto;
      padding: 80px 40px;
      color: #F4F4F5;
      font-family: 'Helvetica Neue', Helvetica, sans-serif;
    }
    .campaign-page .campaign-hero {
      text-align: center;
      margin-bottom: 80px;
    }
    .campaign-page h1 {
      font-size: 4rem;
      font-weight: 900;
      text-transform: uppercase;
      line-height: 0.95;
      margin: 0 0 30px;
      letter-spacing: -3px;
      background: linear-gradient(to bottom, #fff, #999);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
    }
    .campaign-page .hero-body {
      font-size: 1.35rem;
      color: #aaa;
      max-width: 700px;
      margin: 0 auto 40px;
      line-height: 1.6;
    }
    .campaign-page .cta-button {
      display: inline-block;
      background: var(--accent, #FF4500);
      color: #fff;
      padding: 18px 40px;
      font-weight: 900;
      text-transform: uppercase;
      letter-spacing: 2px;
      border-radius: 4px;
      text-decoration: none;
      transition: transform 0.3s, box-shadow 0.3s;
    }
    .campaign-page .cta-button:hover {
      transform: translateY(-3px);
      box-shadow: 0 20px 40px rgba(255, 69, 0, 0.4);
    }
    .campaign-page .pricing {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 30px;
      margin-bottom: 80px;
    }
    .campaign-page .price-card {
      background: rgba(255,255,255,0.03);
      border: 1px solid rgba(255,255,255,0.1);
      border-radius: 16px;
      padding: 40px;
      text-align: center;
    }
    .campaign-page .price-card h3 {
      margin: 0 0 15px;
      text-transform: uppercase;
      color: #fff;
    }
    .campaign-page .price-card .amount {
      font-size: 3rem;
      font-weight: 900;
      color: var(--accent, #FF4500);
    }
  </style>

  <div class="campaign-hero" style="--accent: {{ accent_color }}">
    <h1>{{ label }}</h1>
    <div class="hero-body">{{ content.field_hero_body }}</div>
    <a class="cta-button" href="#contact">{{ content.field_cta_label }}</a>
  </div>

  {% if pricing_snapshot %}
    <div class="pricing" style="--accent: {{ accent_color }}">
      {% for tier, price in pricing_snapshot %}
        <div class="price-card">
          <h3>{{ tier|title }}</h3>
          <div class="amount">${{ (price / 100)|number_format(2) }}</div>
        </div>
      {% endfor %}
    </div>
  {% endif %}

  {{ content|without('field_accent_color', 'field_hero_body', 'field_cta_label', 'field_pricing_snapshot') }}
</article>
